reivo:
  api_key: "rv_your_reivo_key"
  routing:
    enabled: true
    mode: "auto"  # auto / conservative / aggressive
  budget:
    monthly_cap: 100
    pace_control: true
  quality:
    min_score: 0.95
    auto_fallback: true
  notifications:
    daily_report: true
    loop_alert: true
    budget_warning: true
